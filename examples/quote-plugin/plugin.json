{
  "schemaVersion": 1,
  "id": "quote-plugin",
  "version": "0.1.0",
  "main": "./dist/src/index.js",
  "contract": {
    "service": "balance.plugins.quote.v1.QuotePluginService",
    "descriptorSet": "./descriptors/contracts.binpb",
    "protoSources": [
      "./proto/balance/plugins/quote/v1/quote_plugin.proto"
    ]
  },
  "runtime": {
    "language": "node",
    "activation": {
      "mode": "lazy"
    },
    "concurrency": {
      "mode": "serial"
    },
    "initTimeoutMs": 5000,
    "requestTimeoutMs": 10000,
    "idleEvictionMs": 300000
  },
  "observability": {
    "emitLogs": true,
    "emitTraces": true,
    "emitMetrics": true
  }
}
