{
  "schemaVersion": 1,
  "id": "http-plugin",
  "version": "0.1.0",
  "main": "./dist/src/index.js",
  "contract": {
    "service": "balance.plugins.http.v1.HttpPluginService",
    "descriptorSet": "./descriptors/contracts.binpb",
    "protoSources": [
      "./proto/balance/plugins/http/v1/http_plugin.proto"
    ]
  },
  "runtime": {
    "language": "node",
    "activation": {
      "mode": "lazy"
    },
    "concurrency": {
      "mode": "parallel-safe"
    },
    "initTimeoutMs": 5000,
    "requestTimeoutMs": 10000,
    "idleEvictionMs": 300000
  },
  "observability": {
    "emitLogs": true,
    "emitTraces": true,
    "emitMetrics": true
  }
}
